rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function userEmail() {
      return request.auth.token.email;
    }

    function isAdmin() {
      return isSignedIn()
        && userEmail() in [
          "s.dumas974@gmail.com",
          "contact@axe-dossier.fr"
        ];
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isCabinetOwnerOfUser(userId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(userId))
        && get(/databases/$(database)/documents/users/$(userId)).data.cabinetOwnerUid == request.auth.uid;
    }

    function isCabinetMember() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.cabinetMember == true
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.subscriptionActive == true;
    }

    function myCabinetOwnerUid() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.cabinetOwnerUid;
    }

    function isSharedClosure() {
      return isSignedIn()
        && (
          resource.data.sharedWithEmails.hasAny([userEmail()])
          || resource.data.sharedEmails.hasAny([userEmail()])
        );
    }

    match /users/{userId} {

      allow read, write: if isOwner(userId);
      allow read: if isAdmin();

    match /cabinetCollaborators/{collabId} {

  allow read: if isSignedIn()
    && (
      isOwner(userId)
      || resource.data.email == userEmail()
      || isAdmin()
    );

  allow create, delete: if isOwner(userId) || isAdmin();

  allow update: if isOwner(userId) || isAdmin();

  allow update: if isSignedIn()
    && resource.data.email == userEmail()
    && request.resource.data.email == resource.data.email
    && request.resource.data.cabinetOwnerUid == resource.data.cabinetOwnerUid
    && request.resource.data.collaboratorUid == request.auth.uid
    && request.resource.data.status == "active"
    && request.resource.data.active == true;
}  

      match /{document=**} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    match /closures/{closureId} {

      allow create: if isSignedIn()
        && request.resource.data.ownerUid == request.auth.uid;

      allow read, update, delete: if isSignedIn()
        && (
          resource.data.ownerUid == request.auth.uid
          || isSharedClosure()
          || resource.data.cabinetOwnerUid == request.auth.uid
          || (
            isCabinetMember()
            && resource.data.cabinetOwnerUid == myCabinetOwnerUid()
          )
          || isAdmin()
        );
    }

    match /feedback/{feedbackId} {
      allow read: if isSignedIn()
        && resource.data.uid == request.auth.uid;

      allow read, update, delete: if isAdmin();

      allow create: if isSignedIn()
        && request.resource.data.uid == request.auth.uid;
    }
  }
}
