rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function userEmail() {
      return isSignedIn() ? request.auth.token.email : "";
    }

    function isAdmin() {
      return isSignedIn()
        && userEmail() in [
          "s.dumas974@gmail.com",
          "contact@axe-dossier.fr"
        ];
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function userDocExists(uid) {
      return exists(/databases/$(database)/documents/users/$(uid));
    }

    function currentUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isMyCabinetOwner(userId) {
      return isSignedIn()
        && userDocExists(request.auth.uid)
        && currentUserData().cabinetMember == true
        && currentUserData().cabinetOwnerUid == userId;
    }

    function hasSharedWithUid(data) {
      return isSignedIn()
        && data.keys().hasAny(["sharedWithUids"])
        && data.sharedWithUids is list
        && data.sharedWithUids.hasAny([request.auth.uid]);
    }

    function hasSharedWithEmail(data) {
      return isSignedIn()
        && data.keys().hasAny(["sharedWithEmails"])
        && data.sharedWithEmails is list
        && data.sharedWithEmails.hasAny([userEmail()]);
    }

    function hasSharedWithMap(data) {
      return isSignedIn()
        && data.keys().hasAny(["sharedWith"])
        && data.sharedWith is map
        && data.sharedWith.keys().hasAny([userEmail()])
        && data.sharedWith[userEmail()].active == true;
    }

    function isSharedClosure(data) {
      return hasSharedWithUid(data)
        || hasSharedWithEmail(data)
        || hasSharedWithMap(data);
    }

   function canReadClosure(userId, data) {
  return isSignedIn()
    && (
      isOwner(userId)
      || isAdmin()
      || isSharedClosure(data)
      || isMyCabinetOwner(userId)
    );
}

    function canUpdateClosure(userId, data) {
      return isSignedIn()
        && (
          isOwner(userId)
          || isAdmin()
          || isSharedClosure(data)
        );
    }

    // Requêtes collectionGroup("closures")
    match /{path=**}/closures/{closureId} {
      allow read, update: if isSignedIn()
        && (
          isAdmin()
          || isSharedClosure(resource.data)
        );
    }

    // Requêtes collectionGroup("cabinetCollaborators")
    match /{path=**}/cabinetCollaborators/{collabId} {
      allow read: if isSignedIn()
        && (
          isAdmin()
          || resource.data.email == userEmail()
          || resource.data.cabinetOwnerUid == request.auth.uid
        );
    }

    // Requêtes collectionGroup("cabinetSharedClosures")
    match /{path=**}/cabinetSharedClosures/{sharedId} {
      allow read: if isSignedIn()
        && (
          isAdmin()
          || resource.data.cabinetOwnerUid == request.auth.uid
          || isSharedClosure(resource.data)
        );
    }

match /cabinetInvites/{token} {
  allow read: if true;

  allow create: if isSignedIn()
    && request.resource.data.cabinetOwnerUid == request.auth.uid;

  allow update: if isSignedIn()
    && (
      isAdmin()
      || resource.data.cabinetOwnerUid == request.auth.uid
      || resource.data.email == userEmail()
    );

  allow delete: if isAdmin()
    || (
      isSignedIn()
      && resource.data.cabinetOwnerUid == request.auth.uid
    );
}
    match /users/{userId} {

      allow read: if isOwner(userId)
        || isAdmin()
        || isMyCabinetOwner(userId);

      allow write: if isOwner(userId) || isAdmin();

      match /closures/{closureId} {
        allow create: if isOwner(userId) || isAdmin();

        allow read: if canReadClosure(userId, resource.data);

        allow update: if canUpdateClosure(userId, resource.data);

        allow delete: if isOwner(userId) || isAdmin();
      }

     match /cabinetCollaborators/{collabId} {
  allow read: if isSignedIn()
    && (
      isOwner(userId)
      || isAdmin()
      || resource.data.email == userEmail()
      || resource.data.cabinetOwnerUid == request.auth.uid
    );

  allow create, delete: if isOwner(userId) || isAdmin();

  allow update: if isOwner(userId)
    || isAdmin()
    || (
      isSignedIn()
      && resource.data.email == userEmail()
      && request.resource.data.email == resource.data.email
      && request.resource.data.cabinetOwnerUid == resource.data.cabinetOwnerUid
      && request.resource.data.diff(resource.data).changedKeys().hasOnly([
        "status",
        "uid",
        "userUid",
        "collaboratorUid",
        "acceptedAt",
        "activatedAt",
        "updatedAt"
      ])
    );
}

      match /cabinetSharedClosures/{sharedId} {
      allow read: if isSignedIn()
  && (
    isOwner(userId)
    || isAdmin()
    || isMyCabinetOwner(userId)
    || resource.data.cabinetOwnerUid == request.auth.uid
    || isSharedClosure(resource.data)
  ); 

        allow create, update: if isSignedIn()
          && (
            isOwner(userId)
            || isAdmin()
            || resource.data.cabinetOwnerUid == request.auth.uid
            || isSharedClosure(resource.data)
          );

        allow delete: if isOwner(userId) || isAdmin();
      }

      match /{document=**} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    match /feedback/{feedbackId} {
      allow create: if isSignedIn()
        && request.resource.data.uid == request.auth.uid;

      allow read: if isSignedIn()
        && resource.data.uid == request.auth.uid;

      allow read, update, delete: if isAdmin();
    }
  }
}
